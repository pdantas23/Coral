# ══════════════════════════════════════════════════════════════════════════════
# TEMPLATE DE VARIÁVEIS DE AMBIENTE — Coral Acessórios
#
# Copie este arquivo para .env e preencha com os valores reais:
#   cp .env.example .env
#
# Este arquivo É commitado no git (sem valores sensíveis).
# O arquivo .env NÃO é commitado (está no .gitignore).
#
# Onde encontrar cada valor:
#   Supabase  → supabase.flexofertas.shop → Project Settings → API
#   WhatsApp  → número com DDI+DDD, sem espaços (ex: 5589912345678)
# ══════════════════════════════════════════════════════════════════════════════


# ─── Supabase — Prefixo VITE_ → lido pelo frontend (Vite) ───────────────────
# IMPORTANTE: sem barra no final da URL
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ─── Supabase — Sem prefixo → lido apenas pelo servidor Express ──────────────
# Nunca exponha a SERVICE_ROLE_KEY no frontend ou em repositório público.
# IMPORTANTE: sem barra no final da URL
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─── Servidor Express ─────────────────────────────────────────────────────────
# Em dev local: http://localhost:3000
# Em produção (Easy Panel): URL exata do domínio Hostinger, sem barra no final
CORS_ORIGIN=http://localhost:3000


# ─── API — URL base do backend ────────────────────────────────────────────────
# Em dev: deixar vazio (o proxy do Vite encaminha /api → localhost:3001)
# Em produção: definido no .env.production como URL do Easy Panel
VITE_API_URL=


# ─── WhatsApp ─────────────────────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER=
VITE_WHATSAPP_MESSAGE=Olá! Gostaria de um atendimento personalizado.
