    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "knip": "^6.4.1",
    "postcss": "^8.4.47",
    "postcss-load-config": "^4.0.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "5.6.3",
    "vite": "^7.1.7"
  }
