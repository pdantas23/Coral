# ══════════════════════════════════════════════════════════════════════════════
# EASY PANEL — Variáveis de ambiente do servidor (backend Node.js/Docker)
#
# Cole cada linha abaixo no painel: Easy Panel → App → Environment Variables
# Substitua os valores entre < > pelos dados reais do seu projeto.
# NUNCA exponha este arquivo publicamente ou commite com chaves reais.
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API
# IMPORTANTE: sem barra no final da URL

SUPABASE_URL=https://supabase.flexofertas.shop
SUPABASE_ANON_KEY=<cole_aqui_a_anon_key_do_supabase>
SUPABASE_SERVICE_ROLE_KEY=<cole_aqui_a_service_role_key_do_supabase>

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL exata do frontend na Hostinger, sem barra no final.
# Deve coincidir com o domínio que o browser usa para acessar o site.
# Exemplo: https://coralacessorios.com.br
# Se o site responde em www e sem www, escolha apenas UM e redirecione o outro.

CORS_ORIGIN=https://<seu-dominio-na-hostinger>
